  "keywords": [
    "openclaw",
    "feishu",
    "installer",
    "cli",
    "plugin"
  ],
  "homepage": "https://github.com/VegeChou/openclaw-feishu-email-tools#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VegeChou/openclaw-feishu-email-tools.git"
  },
