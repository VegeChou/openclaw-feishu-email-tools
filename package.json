    "test": "npm run build && node --test tests/**/*.test.mjs",
    "prepublishOnly": "npm run lint && npm run test"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "chalk": "^5.4.1",
    "commander": "^14.0.1",
